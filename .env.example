# ── Groq ─────────────────────────────────────────────────────────────
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ── OpenRouter ────────────────────────────────────────────────────────
# Sign up: https://openrouter.ai  →  Keys
# Free:    meta-llama/llama-3.3-70b-instruct:free, google/gemma-4-31b-it:free,
#           nvidia/nemotron-3-super-120b-a12b:free, openai/gpt-oss-120b:free
# Paid:    google/gemini-2.5-flash, google/gemini-2.5-pro, google/gemini-3.1-pro-preview,
#           meta-llama/llama-4-maverick, anthropic/claude-3.5-haiku,
#           anthropic/claude-sonnet-4, openai/gpt-4o-mini
OPENROUTER_API_KEY=

# ── Google Gemini (Direct API) ────────────────────────────────────────
# Sign up: https://aistudio.google.com/app/apikey
# Modeller (Direct API): gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite,
#   gemini-3.5-flash, gemini-3.1-pro-preview, gemini-2.5-computer-use-preview-10-2025
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app

# ── Tavily Web Search ─────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Tool Server ───────────────────────────────────────────────────────
TOOL_SERVER_URL=http://tool-server:8001

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama-local
EMBEDDING_MODEL_NAME=nomic-embed-text
EMBEDDING_DIM=768
EMBEDDING_TIMEOUT=30.0
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BACKOFF=1.5
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_MAX_ENTRIES=1000

# ── RAG / Chunking ────────────────────────────────────────────────────
RAG_SIMILARITY_THRESHOLD=0.65
RAG_DEFAULT_TOP_K=8
MAX_CONTEXT_TOKENS=12000
RAG_TOOL_MAX_CONTEXT_TOKENS=4000
CHUNK_SIZE_TOKENS=150
CHUNK_OVERLAP_TOKENS=30

# ── Reranking (improves retrieval precision) ──────────────────────────
# Sign up: https://jina.ai → API Keys (free tier available)
RERANKER_ENABLED=false
RERANKER_API_KEY=
RERANKER_BASE_URL=https://api.jina.ai/v1
RERANKER_MODEL=jina-reranker-v2-base-multilingual
RERANKER_TIMEOUT=10.0
RERANKER_OVERFETCH_MULTIPLIER=3

# ── Tool flags ────────────────────────────────────────────────────────
WEB_SEARCH_ENABLED=false
CALCULATOR_ENABLED=false

# ── LangSmith Tracing ─────────────────────────────────────────────────
# Sign up: https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=groq-stream-fastapi
LANGSMITH_TRACING_ENABLED=true
